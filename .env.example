# Mirror defaults for users in mainland China (applied automatically at runtime
# when unset). Copy to .env or export before running if you need overrides.

# HuggingFace Hub mirror (MOSS-TTS, GLM-TTS checkpoints)
# HF_ENDPOINT=https://hf-mirror.com

# MOSS-TTS defaults (optional CLI overrides)
# CAPTION_HELPER_TTS_MODEL=local-v1.5-4b
# CAPTION_HELPER_TTS_DEVICE=cuda:1
# CAPTION_HELPER_ASR_DEVICE=cuda:0

# Disable hf_transfer on mirrors that do not support it
# HF_HUB_ENABLE_HF_TRANSFER=0

# uv package index override (project default is Tsinghua PyPI in pyproject.toml)
# UV_INDEX_URL=https://pypi.org/simple

# npm registry override (project default is in frontend/.npmrc)
# npm config set registry https://registry.npmjs.org
